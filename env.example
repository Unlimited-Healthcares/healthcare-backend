# Application Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
API_PREFIX=api

# Database Configuration (Docker)
# If using Docker for database, use these settings:
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password
DB_DATABASE=unlimitedhealthcare_prod

# Alternative Docker database settings (if using different container name/port):
# DB_HOST=your-docker-host-ip
# DB_PORT=5433 (if you mapped to different port)
# DB_USERNAME=your_docker_db_user
# DB_PASSWORD=your_docker_db_password
# DB_DATABASE=unlimitedhealthcare_prod

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=30d

# Redis Configuration (for caching and sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Supabase Configuration (for file storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@unlimtedhealth.com

# Frontend URLs (for CORS)
FRONTEND_URL=https://app.unlimtedhealth.com
WEB_APP_URL=https://www.unlimtedhealth.com

# API Keys for external services
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# Health Check
HEALTH_CHECK_INTERVAL=30000

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# SSL/TLS (for production)
SSL_KEY_PATH=/path/to/ssl/private.key
SSL_CERT_PATH=/path/to/ssl/certificate.crt

# Docker Database Commands (for reference):
# Start PostgreSQL container:
# docker run -d --name postgres-db \
#   -e POSTGRES_PASSWORD=your_secure_password \
#   -e POSTGRES_DB=unlimitedhealthcare_prod \
#   -p 5432:5432 \
#   postgres:13
#
# Connect to database:
# docker exec -it postgres-db psql -U postgres -d unlimitedhealthcare_prod
#
# View database logs:
# docker logs postgres-db
#
# Backup database:
# docker exec postgres-db pg_dump -U postgres unlimitedhealthcare_prod > backup.sql 