{
  "name": "unlimitedhealthcare-backend",
  "version": "1.0.0",
  "description": "Comprehensive Healthcare Management API",
  "author": "UNLIMITEDHEALTHCARE Team",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "node node_modules/@nestjs/cli/bin/nest.js build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "node node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:debug": "node node_modules/@nestjs/cli/bin/nest.js start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix --no-ignore",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix --no-ignore",
    "test": "jest",
    "db:clear": "ts-node scripts/clear-users-database.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:unit": "jest --testPathPattern=src/.*\\.spec\\.ts$",
    "test:integration": "jest --testPathPattern=./test/.*\\.integration-spec\\.ts$ --config=./test/jest-integration.json --passWithNoTests",
    "test:performance": "echo 'Performance tests: Use tools like k6, wrk, or ab for load testing'",
    "test:security": "ts-node test/module-testing/test-security-endpoints.ts",
    "test:security:owasp": "echo 'OWASP ZAP security tests would run here'",
    "test:auth": "ts-node test/module-testing/test-auth-http.ts",
    "test:admin": "ts-node test/module-testing/test-admin-endpoints.ts",
    "test:users": "ts-node test/module-testing/test-users-endpoints.ts",
    "test:centers": "ts-node test/module-testing/test-centers-endpoints.ts",
    "test:blood-donation": "ts-node test/module-testing/test-blood-donation-endpoints.ts",
    "test:referrals": "ts-node test/module-testing/test-referrals-endpoints.ts",
    "test:appointments": "ts-node test/module-testing/test-appointments-endpoints.ts",
    "test:medical-records": "ts-node test/module-testing/test-medical-records-endpoints.ts",
    "test:emergency": "ts-node test/module-testing/test-emergency-endpoints.ts",
    "test:ai": "ts-node test/module-testing/test-ai-endpoints.ts",
    "test:patients": "ts-node test/module-testing/test-patients-endpoints.ts",
    "test:chat": "ts-node test/module-testing/test-chat-endpoints.ts",
    "test:notifications": "ts-node test/module-testing/test-notifications-endpoints.ts",
    "test:location": "ts-node test/module-testing/test-location-endpoints.ts",
    "test:reviews": "ts-node test/module-testing/test-reviews-endpoints.ts",
    "test:integrations": "ts-node test/module-testing/test-integrations-endpoints.ts",
    "test:video-conferencing": "ts-node test/module-testing/test-video-conferencing-endpoints.ts",
    "test:compliance": "ts-node test/module-testing/test-compliance-endpoints.ts",
    "test:audit": "ts-node test/module-testing/test-audit-endpoints.ts",
    "test:cache": "ts-node test/module-testing/test-cache-endpoints.ts",
    "test:equipment-marketplace": "ts-node test/module-testing/test-equipment-marketplace-endpoints.ts",
    "test:supabase": "ts-node test/module-testing/test-supabase-endpoints.ts",
    "test:supabase:service": "ts-node test/module-testing/test-supabase-service.ts",
    "test:websocket": "ts-node test/module-testing/test-websocket-endpoints.ts",
    "test:comprehensive": "ts-node test/module-testing/run-comprehensive-tests.ts",
    "test:comprehensive:setup": "./scripts/setup-test-database.sh && npm run test:comprehensive",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:auth && npm run test:admin",
    "test:ci": "npm run test:unit && npm run test:auth && npm run test:admin",
    "test:quick": "npm run test:auth && npm run test:admin",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/datasource.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/datasource.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/datasource.ts",
    "migration:run:prod": "typeorm migration:run -d dist/datasource.js",
    "migration:revert:prod": "typeorm migration:revert -d dist/datasource.js",
    "seed:run": "ts-node src/database/seeds/run-seeds.ts",
    "db:reset": "npm run migration:revert && npm run migration:run && npm run seed:run",
    "ci:setup": "npm ci && npm run build",
    "ci:test": "npm run test:ci",
    "ci:deploy": "echo 'Deployment scripts would go here'",
    "test:setup-db": "./scripts/setup-test-db.sh",
    "test:setup": "./scripts/setup-testing.sh",
    "test:setup-modules": "./scripts/setup-module-testing.sh",
    "test:modules": "ts-node test/module-testing/run-all-tests.ts",
    "test:module": "ts-node test/module-testing/run-all-tests.ts --module",
    "test:auth-http": "ts-node test/module-testing/test-auth-http.ts",
    "test:comprehensive:quick": "ts-node test/module-testing/comprehensive-module-tests.ts",
    "test:all-modules": "npm run test:comprehensive",
    "test:api-ready": "npm run test:comprehensive && echo '✅ API is ready for frontend development!'",
    "test:db-check": "ts-node -e \"console.log('Database connection check - implement if needed')\"",
    "db:migrate": "npm run typeorm migration:run",
    "db:migrate:revert": "npm run typeorm migration:revert",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seeds/run-seeds.ts",
    "typeorm": "typeorm-ts-node-commonjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.4.19",
    "@nestjs/platform-ws": "^10.4.20",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/serve-static": "^4.0.0",
    "@nestjs/swagger": "^7.1.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^5.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "@supabase/supabase-js": "^2.38.0",
    "@types/bcrypt": "^5.0.2",
    "@types/multer": "^1.4.12",
    "axios": "1.6.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cache-manager": "^6.4.3",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dompurify": "^3.2.6",
    "jsdom": "^26.1.0",
    "moment": "^2.29.4",
    "nodemailer": "^6.9.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.14.0",
    "pg": "^8.11.0",
    "qrcode": "^1.5.3",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.9.4",
    "rxjs": "^7.8.1",
    "sendchamp-sdk": "^1.1.0",
    "sharp": "^0.34.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "4.8.1",
    "stripe": "^20.3.1",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@faker-js/faker": "^9.8.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@pact-foundation/pact": "^15.0.1",
    "@types/bcryptjs": "^2.4.2",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.8",
    "@types/passport-jwt": "^3.0.9",
    "@types/passport-local": "^1.0.35",
    "@types/pdfkit": "^0.13.3",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "codecov": "^3.8.2",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.7",
    "is-ci": "^3.0.1",
    "jest": "^29.5.0",
    "jest-html-reporter": "^4.1.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "../test/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    }
  }
}